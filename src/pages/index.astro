---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import SectionHead from '../components/SectionHead.astro';

const title = 'TokenMonitor — See your AI usage on your desk';
const description =
  'A 4-inch always-on desk display that shows live Claude Code, Codex and Antigravity usage from your laptop.';
---
<Layout
  title={title}
  description={description}
  page="index"
  canonical="https://tokenmonitor.dev/"
  usesDeviceScreens
>
  <!-- ─── Hero ─────────────────────────────────────────────── -->
  <section class="hero container">
    <div class="hero-bg">
      <picture>
        <source media="(max-width: 900px)" srcset="/assets/lead-mobile.jpg" />
        <img
          src="/assets/lead.jpg"
          fetchpriority="high"
          alt="TokenMonitor 4-inch desk display on a wooden desk beside a laptop, showing live Claude Code usage"
        />
      </picture>
      <video autoplay muted loop playsinline preload="auto" poster="/assets/lead.jpg" aria-hidden="true">
        <source src="/assets/desk-loop.webm" type="video/webm" />
        <source src="/assets/desk-loop.mp4" type="video/mp4" />
      </video>
      <span class="proto-tag">Working prototype</span>
    </div>
    <div class="hero-copy">
      <p class="eyebrow">4-inch desk display</p>
      <h1>See your <span class="accent gradient-text">AI usage</span><br />on your desk.</h1>
      <p class="lead">A 4-inch always-on desk display that shows your live Claude Code, Codex and Antigravity usage — straight from the machine you already work on, with the logins you already have.</p>
      <div class="cta-row">
        <a href="#" class="btn btn-primary">Get early access <span class="arrow">→</span></a>
        <a href="/how-it-works.html" class="btn btn-ghost">How it works</a>
      </div>
      <div class="meta-row">
        <span><span class="dot"></span>Real provider limits</span>
        <span><span class="dot"></span>No new API key</span>
        <span><span class="dot"></span>Open-source broker</span>
      </div>
      <p class="hero-price">Ships worldwide &middot; delivery expected before Q4&nbsp;2026</p>
    </div>
    <div class="scroll-cue" aria-hidden="true">
      <span>More below</span>
      <span class="arrow-down"></span>
    </div>
  </section>

  <!-- ─── What it shows ────────────────────────────────────── -->
  <Section>
    <SectionHead eyebrow="What's on screen">
      Three numbers, three sources.
      <Fragment slot="lead">No invented metrics. Each number has a real source — and we're upfront about
      which is measured and which is estimated.</Fragment>
    </SectionHead>
    <div class="shows-grid">
      <article class="shows-card">
        <div class="metric">%</div>
        <span class="src">Real — from the provider</span>
        <h3>Usage limits</h3>
        <p>Your provider's own reported quota, fetched live from its usage API. The bars are real, not a local guess.</p>
      </article>
      <article class="shows-card">
        <div class="metric">tok</div>
        <span class="src">Local — from your machine</span>
        <h3>Token counts</h3>
        <p>Totalled from the CLI logs on the computer running the broker. No API key, and reading them costs you nothing.</p>
      </article>
      <article class="shows-card">
        <div class="metric">$</div>
        <span class="src">Estimated — list prices</span>
        <h3>Spend</h3>
        <p>Token counts × a public price list. A useful estimate, not a bill — on a subscription plan it's notional, not money charged.</p>
      </article>
    </div>
  </Section>

  <!-- ─── How it works (compact) ───────────────────────────── -->
  <Section>
    <SectionHead eyebrow="How it fits together">
      Device. Broker. Plugin.
      <Fragment slot="lead">A small open-source server on your laptop reads your CLI usage; the device
      polls it over your Wi-Fi; a one-line marketplace plugin pairs the two from your AI.</Fragment>
    </SectionHead>
    <div class="hiw-mini">
      <div class="node">
        <span class="k">On your laptop</span>
        <h3>The broker</h3>
        <p>The <code class="inline-code">tokenmonitor-mcp</code> server reads your Claude Code / Codex / Antigravity logs and serves the numbers.</p>
      </div>
      <div class="arr">⇄</div>
      <div class="node accent">
        <span class="k">On your desk</span>
        <h3>The device</h3>
        <p>Polls the broker over your LAN and draws the dashboard. Holds no provider logins of its own.</p>
      </div>
      <div class="arr">+</div>
      <div class="node">
        <span class="k">In your AI</span>
        <h3>The plugin</h3>
        <p>Installed from the marketplace. You pair the device by asking your AI to run <a href="/plugin.html#skills"><code class="inline-code">/tokenmonitor:configure</code></a>.</p>
      </div>
    </div>
    <div class="hiw-foot">
      <a href="/how-it-works.html" class="btn btn-ghost">See the full data path <span class="arrow">→</span></a>
      <a href="/plugin.html#skills" class="btn btn-ghost">Skills &amp; MCP tools <span class="arrow">→</span></a>
    </div>
  </Section>

  <!-- ─── Trust / privacy band ─────────────────────────────── -->
  <Section>
    <div class="trust">
      <p class="eyebrow" style="color:#10b981">Is it safe?</p>
      <h2>Your code stays yours.</h2>
      <p class="lead" style="max-width:60ch">The specific version — not a "trust us" badge.</p>
      <div class="trust-grid">
        <div class="pt"><span class="ck">✓</span><p><strong>It isn't built to read or send your prompts or code.</strong> The broker parses usage and token counts out of your local logs — there's no path that ships their contents anywhere, and it's open source so you can verify that.</p></div>
        <div class="pt"><span class="ck">✓</span><p><strong>The server is open source (Apache-2.0).</strong> The part that runs on your laptop and touches your logs is yours to read, line by line.</p></div>
        <div class="pt"><span class="ck">✓</span><p><strong>No inbound exposure.</strong> The broker only listens on your LAN for the device (port 8765) — nothing to forward from the internet, no telemetry, no analytics. Its outbound calls go to your providers and a price list, nowhere else.</p></div>
        <div class="pt"><span class="ck">✓</span><p><strong>The device doesn't phone home to us.</strong> Its only direct internet calls are a public clock server and the weather — never an AI provider, never your usage data.</p></div>
        <div class="pt"><span class="ck">✓</span><p><strong>No account with us, no cloud lock-in.</strong> You use the provider logins you already have. There's no Fractal Manifold sign-up.</p></div>
        <div class="pt"><span class="ck">✓</span><p><strong>Signed requests &amp; signed firmware.</strong> Device polls are HMAC-signed and replay-protected; updates are Ed25519-signed with automatic rollback.</p></div>
      </div>
      <div class="trust-links">
        <a href="/how-it-works.html#security">Read the full security model →</a>
        <a href="/faq.html#security">Security &amp; privacy FAQ →</a>
      </div>
    </div>
  </Section>

  <!-- ─── Theme lab (interactive — providers + themes) ─────── -->
  <Section id="themes">
    <div class="section-head" style="text-align:center; max-width:780px; margin:0 auto 2.5rem;">
      <p class="eyebrow">Three providers · day, night &amp; auto</p>
      <h2>One panel, dressed for the model.</h2>
      <div class="rule" style="margin:1.5rem auto;"></div>
      <p class="lead" style="margin:0 auto;">Claude Code, Codex and Antigravity each get their own brand-tinted palette in a day and a night flavour — six looks, drawn pixel-exact at 480×480. Auto follows your city's real sunrise and sunset; or lock one with a tap, or set it from your CLI. Try it:</p>
    </div>
    <div class="theme-lab">
      <div class="theme-controls">
        <div class="seg-group">
          <span class="seg-cap">Provider</span>
          <div class="tabs" data-seg="provider">
            <button type="button" class="tab active" data-provider="claude"><span class="swatch claude"></span>Claude</button>
            <button type="button" class="tab" data-provider="codex"><span class="swatch codex"></span>Codex</button>
            <button type="button" class="tab" data-provider="antigravity"><span class="swatch antigravity"></span>Antigravity</button>
          </div>
        </div>
        <div class="seg-group">
          <span class="seg-cap">Theme</span>
          <div class="tabs" data-seg="mode">
            <button type="button" class="tab active" data-mode="day">Day</button>
            <button type="button" class="tab" data-mode="night">Night</button>
            <button type="button" class="tab" data-mode="auto">Auto</button>
          </div>
        </div>
        <p class="theme-hint" id="themeHint"></p>
      </div>
      <div class="theme-device">
        <div class="device-frame">
          <div class="screen" data-tmon-screen="claude-day" id="themeScreen"></div>
        </div>
      </div>
    </div>
    <div class="midcta">
      <a href="#" class="btn btn-primary">Get early access <span class="arrow">→</span></a>
    </div>
  </Section>

  <!-- ─── Custom panel (make it yours) ─────────────────────── -->
  <Section id="custom-panel">
    <SectionHead eyebrow="Beyond the dashboard">
      Bring your own charts.
      <Fragment slot="lead">Swipe up for a screen that's entirely yours. A tiny script on your laptop writes a JSON file; the broker serves it over the same secure channel; the device draws it as a line, bar, pie, table or text — in your own colors.</Fragment>
    </SectionHead>
    <div class="panel-cta">
      <div class="device-frame">
        <div class="screen">
          <div class="tmon-panel">
            <div class="tmon-panel__bar">
              <span class="tmon-panel__back">‹ Back</span>
              <span class="tmon-panel__title" style="color:#e0894a">Sesión</span>
            </div>
            <div class="tmon-panel__sub" style="color:#c15f3c">Tokens/min</div>
            <div class="tmon-panel__body">
              <div class="tmon-panel__chart">
                <svg viewBox="0 0 100 60" preserveAspectRatio="none" fill="none" stroke-linejoin="round" stroke-linecap="round">
                  <polyline points="2,37.9 26,27.8 50,42.9 74,17.7 98,6" stroke="#c15f3c" stroke-width="1.8"/>
                  <polyline points="2,51.3 26,46.3 50,53 74,39.5 98,32.8" stroke="#e07a4a" stroke-width="1.8"/>
                </svg>
              </div>
              <div class="tmon-panel__legend">
                <span><b style="background:#c15f3c"></b>in</span>
                <span><b style="background:#e07a4a"></b>out</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div>
        <span class="swipe-tag"><span class="dot" style="width:6px;height:6px;border-radius:50%;background:var(--color-gold)"></span>Swipe up to reach it</span>
        <ul>
          <li>Any data you can measure — tokens/min, RAM, spend, build times, whatever your script emits.</li>
          <li>Five widgets: line, bar, pie/donut, key-value table, big text.</li>
          <li>Your palette — set a color on every series, slice, row, title and background.</li>
          <li><span>Edit the file and the device picks it up within a poll — set <code class="inline-code">poll_s</code> for a near-live refresh.</span></li>
          <li>Off by default, open-source broker, no cloud round-trip.</li>
        </ul>
        <a href="/setup.html#custom-panel" class="btn btn-ghost">Set up your own panel <span class="arrow">→</span></a>
      </div>
    </div>
  </Section>

  <!-- ─── Why a device (merged with features) ──────────────── -->
  <Section>
    <SectionHead eyebrow="Why a dedicated display">
      Glance, don't query.
      <Fragment slot="lead">You can type a command or open a menubar widget — but the moment you're deep in a task is exactly when you won't. An always-on panel tells you the answer before you remember to ask.</Fragment>
    </SectionHead>
    <div class="why-grid">
      <article class="why-card">
        <div class="k">Always-on</div>
        <h3>No window to open</h3>
        <p>It just sits there, lit. No command, no tab, no notch widget fighting for your menubar — you glance and you know.</p>
      </article>
      <article class="why-card">
        <div class="k">Off your screen</div>
        <h3>Frees your pixels</h3>
        <p>Usage lives on the desk, not in your editor. Nothing to dismiss, nothing covering your code.</p>
      </article>
      <article class="why-card">
        <div class="k">Calm by design</div>
        <h3>Ambient, never nagging</h3>
        <p>Standby after 20 min, day/night dimming, alert volume you set. The few alerts that fire — low battery, limit overshoot, session rollover — are debounced so they never spam you.</p>
      </article>
    </div>
    <p class="why-note"><strong>Not a CLI replacement.</strong> It's the at-a-glance layer on top of the tools you already run.</p>
  </Section>

  <!-- ─── Common concerns ──────────────────────────────────── -->
  <Section>
    <div class="section-head" style="text-align:center; max-width:680px; margin:0 auto 1rem;">
      <p class="eyebrow">Before you ask</p>
      <h2>Common concerns.</h2>
      <div class="rule" style="margin:1.5rem auto;"></div>
    </div>
    <div class="accordion concerns">
      <details class="acc-item">
        <summary class="acc-summary">Does it cost me tokens or money to run? <span class="plus">+</span></summary>
        <div class="acc-body">
          <p>No. There's no new API key and no extra tokens spent. Token counts are read from logs already on your machine, and the limit percentages come from each provider's usage API — a read, not a request that bills you. The dollar figure is an <em>estimate</em> from public list prices, not a charge. <a href="/faq.html#general">More in the FAQ →</a></p>
        </div>
      </details>
      <details class="acc-item">
        <summary class="acc-summary">Do I have to flash firmware or use a terminal? <span class="plus">+</span></summary>
        <div class="acc-body">
          <p>No flashing — units ship pre-flashed. You plug in USB-C, join the device's Wi-Fi once to enter your network, then pair it by asking your AI to run a skill. On your computer you install the <code class="inline-code">tokenmonitor-mcp</code> broker (one command) plus the marketplace plugin that runs it — nothing is flashed. <a href="/setup.html">See the 5-step setup →</a></p>
        </div>
      </details>
      <details class="acc-item">
        <summary class="acc-summary">What if I only use one provider — or not Claude Code? <span class="plus">+</span></summary>
        <div class="acc-body">
          <p>Enable one or all three. It works with Claude Code, Codex CLI and the Antigravity CLI; a provider whose CLI you don't run simply doesn't appear on the device. The pairing plugin installs into whichever of those you use. <a href="/faq.html#general">Provider details →</a></p>
        </div>
      </details>
      <details class="acc-item">
        <summary class="acc-summary">It's indie hardware — what if you disappear? <span class="plus">+</span></summary>
        <div class="acc-body">
          <p>The broker and plugin are open source (Apache-2.0), so the device keeps working whether or not we're around — you can run, audit and fork the server yourself. The limit, plainly: new hardware, repairs and future firmware signing depend on us continuing. <a href="/faq.html#firmware">Firmware &amp; longevity →</a></p>
        </div>
      </details>
    </div>
  </Section>

  <!-- ─── Spec strip ───────────────────────────────────────── -->
  <Section spacing="tight">
    <div class="spec-strip">
      <span><span class="num">480 × 480</span>capacitive</span>
      <span><span class="num">2.4 GHz</span>Wi-Fi</span>
      <span><span class="num">86 × 86</span>mm</span>
    </div>
  </Section>

  <!-- ─── Waitlist ─────────────────────────────────────────── -->
  <Section id="waitlist">
    <div class="waitlist">
      <span class="badge"><span class="pulse"></span>Early access · first 100</span>
      <h2>Get early access.</h2>
      <p class="price-meta">Ships worldwide &middot; delivery expected before Q4&nbsp;2026</p>
      <p class="sub">The first run is a small, carefully assembled batch — each unit pre-flashed and tested, ready to pair out of the box. We're finalising production with a manufacturing partner now; join the waitlist and we'll email you the moment units open.</p>
      <div class="cta-row" style="display:flex; gap:1rem; flex-wrap:wrap;">
        <a href="#" class="btn btn-primary">Get early access <span class="arrow">→</span></a>
      </div>
    </div>
  </Section>

  <!-- ─── Closing micro-CTA ────────────────────────────────── -->
  <Section spacing="flush">
    <div style="text-align:center; padding: 3rem 0; color: var(--fg-3); font-size: 0.95rem;">
      Already have a unit? <a href="/setup.html" style="color: var(--color-gold-light); text-decoration: underline; text-decoration-color: rgba(245,158,11,0.4);">Jump to setup →</a>
    </div>
  </Section>
</Layout>

<script>
  // Fade out the "More below" cue once the user has scrolled past the hero.
  (function () {
    const cue = document.querySelector('.scroll-cue');
    if (!cue) return;
    function update() {
      cue.classList.toggle('is-hidden', window.scrollY > 40);
    }
    window.addEventListener('scroll', update, { passive: true });
    update();
  })();

  // Interactive theme lab: provider × (day | night | auto) → live device preview.
  (function () {
    const screen = document.getElementById('themeScreen');
    const hint = document.getElementById('themeHint');
    if (!screen || !window.TMON) return;
    let provider = 'claude', mode = 'day';
    const hints = {
      day:   'Day palette — bright and high-contrast for a lit desk.',
      night: "Night palette — dimmed and warm so it doesn't glare after dark.",
      auto:  "Auto follows your city's real sunrise & sunset. In this preview it tracks the page's light/dark toggle (top-right)."
    };
    function apply() {
      if (mode === 'auto') {
        screen.setAttribute('data-tmon-screen', provider + '-day');
        screen.setAttribute('data-tmon-theme', 'auto');
      } else {
        screen.setAttribute('data-tmon-screen', provider + '-' + mode);
        screen.removeAttribute('data-tmon-theme');
      }
      if (hint) hint.textContent = hints[mode];
      window.TMON.mount();
    }
    function wire(sel, set) {
      document.querySelectorAll(sel + ' .tab').forEach(btn => {
        btn.addEventListener('click', () => {
          set(btn);
          btn.parentElement.querySelectorAll('.tab').forEach(x => x.classList.toggle('active', x === btn));
          apply();
        });
      });
    }
    wire('[data-seg="provider"]', b => { provider = b.getAttribute('data-provider'); });
    wire('[data-seg="mode"]',     b => { mode = b.getAttribute('data-mode'); });
    apply();
  })();
</script>

<style is:global>
  /* ── Landing-specific ───────────────────────────────────── */
  .hero {
    position: relative;
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    padding: 5rem 0 6rem 0;
    isolation: isolate;
  }
  /* Full-bleed product photo behind the copy — device stays clear on the left,
     copy sits on the right over a scrim. */
  .hero-bg {
    position: absolute;
    top: 0; bottom: 0; left: 50%;
    width: 100vw;
    transform: translateX(-50%);
    z-index: -1;
    overflow: hidden;
  }
  .hero-bg img,
  .hero-bg video {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 42%;
    display: block;
  }
  /* The loop plays over the still, which stays as the LCP paint and the
     fallback. Both are framed identically, so the swap is invisible. */
  .hero-bg video {
    position: absolute;
    inset: 0;
  }
  /* Mobile keeps the still: the copy drops below the photo there, the portrait
     crop (lead-mobile.jpg) has no video equivalent, and autoplay is a data cost
     users didn't ask for. */
  @media (max-width: 900px) {
    .hero-bg video { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-bg video { display: none; }
  }
  .hero-bg::after {
    content: '';
    position: absolute; inset: 0;
    background:
      linear-gradient(90deg, rgba(10,10,10,0) 22%, rgba(10,10,10,0.55) 45%, rgba(10,10,10,0.82) 66%, rgba(10,10,10,0.92) 100%),
      linear-gradient(180deg, rgba(10,10,10,0.3) 0%, rgba(10,10,10,0) 24%, rgba(10,10,10,0) 60%, rgba(10,10,10,0.72) 100%);
  }
  .hero-copy {
    position: relative;
    z-index: 1;
    max-width: 32rem;
    margin-left: auto;
  }
  /* The hero is a dark photo section inside an otherwise light-themed site:
     on desktop the copy sits over the scrim, so force it light. On mobile the
     copy drops below the photo onto the light page bg — keep the theme colors. */
  @media (min-width: 901px) {
    .hero .hero-copy h1 { color: #f7f4ee; text-shadow: 0 2px 24px rgba(0,0,0,0.35); }
    .hero .hero-copy .lead { color: #f4f0e8; text-shadow: 0 1px 14px rgba(0,0,0,0.6); }
    .hero .hero-copy .meta-row { color: rgba(247,244,238,0.85); }
    .hero .hero-copy .hero-price { color: rgba(247,244,238,0.85); }
    .hero .hero-copy .btn-ghost { color: #f7f4ee; border-color: rgba(255,255,255,0.32); }
    .hero .hero-copy .btn-ghost:hover { color: #fff; border-color: rgba(255,255,255,0.55); }
  }
  .scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 1.5rem;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.68rem;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--fg-3);
    pointer-events: none;
    user-select: none;
    opacity: 0.85;
    transition: opacity 0.35s ease;
  }
  .scroll-cue.is-hidden { opacity: 0; }
  .scroll-cue .arrow-down {
    width: 14px; height: 14px;
    border-right: 2px solid var(--color-gold);
    border-bottom: 2px solid var(--color-gold);
    transform: rotate(45deg);
    animation: cue-bounce 1.8s ease-in-out infinite;
  }
  @keyframes cue-bounce {
    0%, 100% { transform: rotate(45deg) translate(0, 0); opacity: 0.55; }
    50%      { transform: rotate(45deg) translate(4px, 4px); opacity: 1; }
  }
  .hero h1 {
    font-size: clamp(2.4rem, 5.4vw, 4.6rem);
    line-height: 1.02;
    letter-spacing: -1px;
    margin-bottom: 1.75rem;
    font-weight: 700;
  }
  .hero h1 .accent { color: var(--color-gold); }
  .hero .lead {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--fg-2);
    margin-bottom: 2rem;
    max-width: 52ch;
    font-weight: 500;
  }
  .hero .cta-row { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3rem; }
  .hero .meta-row {
    display: flex; gap: 2rem;
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .hero .meta-row span { display: flex; align-items: center; gap: 0.5rem; }
  .hero .meta-row .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-gold); }

  /* ── Waitlist ───────────────────────────────────────────── */
  .waitlist {
    position: relative;
    padding: 5rem 3rem;
    background: linear-gradient(135deg, rgba(245,158,11,0.06) 0%, rgba(147,51,234,0.06) 100%), var(--color-bg-tertiary);
    border: 1px solid rgba(245,158,11,0.20);
    border-radius: var(--radius-xl);
    backdrop-filter: blur(8px);
    overflow: hidden;
  }
  .waitlist::before {
    content: '';
    position: absolute;
    inset: -50%;
    background:
      radial-gradient(circle at 20% 30%, rgba(245,158,11,0.18) 0%, transparent 35%),
      radial-gradient(circle at 80% 70%, rgba(147,51,234,0.16) 0%, transparent 40%);
    pointer-events: none;
  }
  .waitlist > * { position: relative; }
  .waitlist .badge {
    display: inline-flex; align-items: center; gap: 0.55rem;
    font-size: 0.74rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-gold);
    background: rgba(245,158,11,0.10);
